{
  "mcpServers": {
    "druid-mcp-server": {
      "command": "jbang",
      "args": [
        "druid-mcp-server@iunera/druid-mcp-server"
      ],
      "env": {
        "DRUID_ROUTER_URL": "http://localhost:8888",
        "DRUID_AUTH_USERNAME": "admin",
        "DRUID_AUTH_PASSWORD": "password",
        "DRUID_SSL_ENABLED": "false",
        "DRUID_SSL_SKIP_VERIFICATION": "false"
      }
    }
  }
}
